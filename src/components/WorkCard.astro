---
import type { WorkItem } from '../data/work';

interface Props {
  item: WorkItem;
}

const { item } = Astro.props;
---
<div class="card p-6 sm:p-8 mb-4">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
    <div>
      <h3 class="text-lg font-semibold text-white">{item.company}</h3>
      <p class="text-accent2 text-sm mt-0.5">{item.role}</p>
      {item.subrole && (
        <p class="text-fg-dim text-xs mt-1 font-mono">{item.subrole}</p>
      )}
    </div>
    <span class="text-xs text-fg-dim font-mono shrink-0">{item.period}</span>
  </div>

  <!-- Description -->
  <p class="text-fg-muted text-sm leading-relaxed mb-5">{item.description}</p>

  <!-- Metrics -->
  {item.metrics && item.metrics.length > 0 && (
    <div class="flex flex-wrap gap-x-8 gap-y-3 mb-5 py-4 border-t border-b border-border">
      {item.metrics.map(m => (
        <div>
          <span class="text-lg font-bold text-white metric-value">{m.value}</span>
          <span class="text-xs text-fg-dim ml-1.5">{m.label}</span>
        </div>
      ))}
    </div>
  )}

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    {item.tags.map(t => (
      <span class:list={['tag', t.highlight && 'tag-accent']}>
        {t.label}
      </span>
    ))}
  </div>
</div>

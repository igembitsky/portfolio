---
const narrative = [
  {
    era: 'Science',
    desc: 'Neuroscience researcher. Co-authored published research. Built the lab\'s experimental processes from scratch as the first research hire. Performed ~700 neo-natal rat surgeries in the name of science.',
  },
  {
    era: 'Media',
    desc: 'Ran video production end-to-end: research, scripts, directing, post-production, release. Then built an online education platform for 1,000+ students and 30+ programs.',
  },
  {
    era: 'Product',
    desc: 'Shipped 10+ apps zero-to-one at HappyFunCorp for clients including Harvard and the Brooklyn Museum. Then first product hire at VDB, where I built the entire product and design team and turned a free marketplace into a revenue-generating platform: a white-label app factory with APIs and integrations, hundreds of jewelers onboard, and active usage scaling 60x.',
  },
  {
    era: 'Operations',
    desc: 'Owned both ends of the revenue lifecycle. Built Customer Success from the ground up to stop the churn and shrink time-to-value, then rebuilt SalesOps, turning ad-hoc, rep-by-rep prospecting into a structured Salesforce engine that lifted deal velocity and gave leadership a pipeline they could reliably forecast.',
  },
  {
    era: 'Builder',
    desc: 'Leading product, sales, and CS at an industrial AI company. Built the full operational framework: GTM engine, safety analytics dashboard, pilot management system, compliance documentation.',
  },
];

const metrics = [
  { value: '7', suffix: '+', label: 'teams & orgs built from zero' },
  { value: '10', suffix: '+', label: 'industries crossed' },
  { value: '14', suffix: 'yrs', label: 'in product & operations' },
  { value: '3', suffix: '', label: 'peer-reviewed publications' },
];
---
<section class="container py-24">
  <div class="reveal">
    <h2 class="text-xs font-mono uppercase tracking-widest text-accent mb-12">The Arc</h2>
  </div>

  <div class="grid md:grid-cols-5 gap-12 items-start">
    <!-- Left: Short intro -->
    <div class="md:col-span-2">
      <div class="reveal">
        <p class="text-lg text-fg leading-relaxed">
          Fourteen years across science, education, media, fintech, and industrial AI.
          I lead teams, build organizations, and ship products.
        </p>
      </div>
    </div>

    <!-- Right: Narrative Arc -->
    <div class="md:col-span-3 space-y-0">
      {narrative.map((item, i) => (
        <div class="reveal flex items-start gap-4 py-4 border-b border-border last:border-0" style={`transition-delay: ${i * 0.06}s`}>
          <span class="text-accent font-mono text-sm font-medium min-w-[90px] shrink-0">{item.era}</span>
          <span class="text-fg-muted text-sm leading-relaxed">{item.desc}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Metrics bar -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mt-16 pt-10 border-t border-border">
    {metrics.map((m, i) => (
      <div class="reveal text-center sm:text-left" style={`transition-delay: ${i * 0.08}s`}>
        <div class="text-3xl sm:text-4xl font-bold text-white metric-value leading-none">
          {m.value}<span class="text-accent">{m.suffix}</span>
        </div>
        <div class="text-xs text-fg-muted mt-2 font-mono leading-snug">{m.label}</div>
      </div>
    ))}
  </div>
</section>

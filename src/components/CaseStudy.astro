---
const features = [
  {
    title: 'Incident Management',
    desc: 'Triage workflows where operators can confirm, dismiss, or escalate safety events. Rich detail views with video playback, timestamps, and metadata.',
  },
  {
    title: 'Analytics & Patterns',
    desc: 'Pattern analysis that turns raw incident data into visual trends across time periods. Helps safety teams spot what matters.',
  },
  {
    title: 'Human-in-the-Loop AI',
    desc: 'AI drafts response messages that humans review and approve before sending. The system learns which suggestions get used and which get rewritten.',
  },
  {
    title: 'Configurable Rules',
    desc: 'Safety rules and thresholds that operators adjust per environment. Full activity history and audit trail so nothing happens invisibly.',
  },
];

const tools = ['Claude Code', 'Codex', 'Figma MCP', 'React', 'AWS SAM', 'DynamoDB'];
---
<section class="container py-24">
  <div class="reveal">
    <h2 class="text-xs font-mono uppercase tracking-widest text-accent mb-4">Case Study</h2>
  </div>

  <div class="card p-8 sm:p-12 border-accent/20 bg-gradient-to-br from-surface via-surface to-accent-soft">
    <div class="reveal">
      <p class="text-accent font-mono text-xs uppercase tracking-widest mb-4">Canary &middot; 2025</p>
      <h3 class="text-2xl sm:text-3xl font-bold text-white leading-tight mb-2">
        Shipping Production SaaS<br class="hidden sm:block" /> with Generative Engineering
      </h3>
      <p class="text-fg-muted text-base max-w-2xl mt-4 leading-relaxed">
        I'm a product leader, not a trained software engineer. But I built Canary's entire
        customer-facing application using generative engineering tools. Not a prototype or a
        demo. A real product with paying customers, real workflows, and design-system-level polish.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid sm:grid-cols-2 gap-5 mt-10">
      {features.map((f, i) => (
        <div class="reveal border border-border rounded-lg p-5 bg-bg/40" style={`transition-delay: ${i * 0.08}s`}>
          <h4 class="text-sm font-semibold text-white mb-2">{f.title}</h4>
          <p class="text-xs text-fg-muted leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>

    <!-- Tools used -->
    <div class="reveal mt-8 pt-6 border-t border-border/50">
      <span class="text-xs text-fg-dim font-mono">Built with</span>
      <div class="flex flex-wrap gap-2 mt-3">
        {tools.map(t => (
          <span class="tag tag-accent">{t}</span>
        ))}
      </div>
    </div>

    <!-- Pull quote -->
    <div class="reveal mt-10 pt-8 border-t border-border/50">
      <blockquote class="text-fg text-sm sm:text-base leading-relaxed italic max-w-2xl">
        "We needed a product and didn't have an engineering team yet. So I built it.
        Incident triage, video review, pattern analysis, configurable safety rules,
        a human-in-the-loop messaging system, fully responsive. All shipped to production,
        all serving real customers."
      </blockquote>
    </div>
  </div>
</section>

---
const links = [
  { label: 'About', href: '#about' },
  { label: 'Work', href: '#canary' },
  { label: 'Projects', href: '#projects' },
  { label: 'Contact', href: '#contact' },
];
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-bg/80 backdrop-blur-md border-b border-border/50">
  <div class="container flex justify-between items-center py-4">
    <a href="#about" class="font-semibold text-sm text-white tracking-tight hover:text-accent transition-colors duration-200">
      IG
    </a>
    <div class="flex items-center gap-1">
      {links.map(link => (
        <a
          href={link.href}
          class="text-fg-muted text-xs sm:text-sm px-3 py-1.5 rounded-md hover:text-fg hover:bg-surface transition-all duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

---
import type { PortfolioItem } from '../data/portfolio';

interface Props {
  item: PortfolioItem;
}

const { item } = Astro.props;
const hasExpand = item.sections && Object.keys(item.sections).length > 0;
const panelId = `panel-${item.id}`;
---
<div class="portfolio-card card p-6 sm:p-8">
  <!-- Header -->
  <div class="mb-3">
    <h3 class="text-base font-semibold text-white">{item.title}</h3>
    <p class="text-fg-muted text-xs mt-1">{item.subtitle}</p>
  </div>

  <!-- Outcome -->
  {item.outcome && (
    <p class="text-accent2 text-sm font-medium mb-3">{item.outcome}</p>
  )}

  <!-- Highlights -->
  <ul class="space-y-1.5 mb-4">
    {item.highlights.map(h => (
      <li class="text-fg-muted text-sm leading-relaxed flex items-start gap-2">
        <span class="text-fg-dim mt-1.5 shrink-0 w-1 h-1 rounded-full bg-fg-dim"></span>
        {h}
      </li>
    ))}
  </ul>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5 mb-3">
    {item.tags.map(t => (
      <span class="tag text-[12px]">{t}</span>
    ))}
  </div>

  <!-- Expand trigger -->
  {hasExpand && (
    <button
      class="expand-trigger"
      data-expand-trigger
      aria-expanded="false"
      aria-controls={panelId}
    >
      Details <span class="expand-icon">+</span>
    </button>
  )}

  <!-- Expandable panel -->
  {hasExpand && item.sections && (
    <div class="card-expand-panel" id={panelId} aria-hidden="true">
      <div>
        <div class="space-y-5 pt-4 border-t border-border">
          {item.sections.context && (
            <div>
              <p class="detail-label">Context</p>
              <p class="text-fg-muted text-sm leading-relaxed">{item.sections.context}</p>
            </div>
          )}
          {item.sections.built && (
            <div>
              <p class="detail-label">What I Built</p>
              <p class="text-fg-muted text-sm leading-relaxed">{item.sections.built}</p>
            </div>
          )}
          {item.sections.decisions && (
            <div>
              <p class="detail-label">Key Decisions</p>
              <p class="text-fg-muted text-sm leading-relaxed">{item.sections.decisions}</p>
            </div>
          )}
          {item.sections.outcomes && (
            <div>
              <p class="detail-label">Outcomes</p>
              <p class="text-fg-muted text-sm leading-relaxed">{item.sections.outcomes}</p>
            </div>
          )}
          {item.sections.tech && item.sections.tech.length > 0 && (
            <div>
              <p class="detail-label">Tech Stack</p>
              <div class="flex flex-wrap gap-1.5">
                {item.sections.tech.map(t => (
                  <span class="tag tag-accent text-[12px]">{t}</span>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  )}
</div>

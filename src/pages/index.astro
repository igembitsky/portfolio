---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import WorkCard from '../components/WorkCard.astro';
import BuildCard from '../components/BuildCard.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { work } from '../data/work';
import { builds } from '../data/builds';
---
<BaseLayout>
  <Nav />
  <main>
    <Hero />
    <hr class="border-t border-border mx-4 sm:mx-8" id="work">
    <SectionHeader label="work" />
    <section class="px-4 sm:px-8 pb-16 max-w-4xl">
      {work.map((item, i) => (
        <div class="reveal" style={`transition-delay: ${i * 0.1}s`}>
          <WorkCard item={item} />
        </div>
      ))}
    </section>
    <hr class="border-t border-border mx-4 sm:mx-8" id="builds">
    <SectionHeader label="builds" />
    <section class="px-4 sm:px-8 pb-16 max-w-4xl">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {builds.map((item, i) => (
          <div class="reveal" style={`transition-delay: ${i * 0.1}s`}>
            <BuildCard item={item} />
          </div>
        ))}
      </div>
    </section>
    <Contact />
    <Footer />
  </main>
</BaseLayout>

    <div class="wiki-modal__backdrop" data-wiki-close></div>
    <div class="wiki-modal__panel" role="dialog" aria-modal="true" aria-label="Wikipedia: The purpose of a system is what it does">
      <div class="wiki-modal__bar">
        <span class="wiki-modal__title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3.6 9h16.8M3.6 15h16.8M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>
          <span>en.wikipedia.org</span>
        </span>
        <div class="wiki-modal__actions">
          <a class="wiki-modal__open" href="https://en.wikipedia.org/wiki/The_purpose_of_a_system_is_what_it_does" target="_blank" rel="noopener noreferrer">
            <span>Open</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M8 7h9v9"/></svg>
          </a>
          <button type="button" class="wiki-modal__close" data-wiki-close aria-label="Close">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
          </button>
        </div>
      </div>
      <div class="wiki-modal__stage" data-wiki-stage>
        <div class="wiki-modal__loader">
          <span class="wiki-spinner"></span>
          <span>Loading Wikipedia…</span>
        </div>
        <iframe
          class="wiki-modal__frame"
          title="Wikipedia: The purpose of a system is what it does"
          referrerpolicy="no-referrer"
          sandbox="allow-scripts allow-same-origin allow-popups allow-popups-to-escape-sandbox"
        ></iframe>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const colors = [
  { name: 'bg', value: '#0b0b0f', note: 'page background' },
  { name: 'surface', value: '#13131a', note: 'cards, raised blocks' },
  { name: 'surface-hover', value: '#1c1c28', note: 'hover state' },
  { name: 'border', value: '#1e1e2e', note: 'card borders, dividers' },
  { name: 'border-hover', value: '#2e2e42', note: 'hover borders' },
  { name: 'fg', value: '#ece8e1', note: 'primary text' },
  { name: 'fg-muted', value: '#b4afbe', note: 'secondary text (just bumped)' },
  { name: 'fg-dim', value: '#807c8d', note: 'tertiary / captions (just bumped)' },
  { name: 'accent', value: '#c8a55a', note: 'gold — primary accent' },
  { name: 'accent2', value: '#7ba1c7', note: 'blue — secondary accent' },
  { name: 'white', value: '#ffffff', note: 'headings' },
];
---
<BaseLayout title="Style guide">
  <main class="container py-16">
    <header class="mb-12">
      <p class="text-fg-muted text-sm font-mono mb-3">Internal</p>
      <h1 class="text-4xl font-bold text-white tracking-tight">Style guide</h1>
      <p class="mt-3 text-fg-muted">Visual reference of all tokens. Not linked from nav.</p>
    </header>

    <!-- Colors -->
    <section class="mb-16">
      <h2 class="text-xs font-mono uppercase tracking-widest text-accent mb-6">Colors</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {colors.map((c) => (
          <div class="card p-4 flex items-center gap-4">
            <div
              class="w-14 h-14 rounded-lg border border-border shrink-0"
              style={`background:${c.value}`}
            />
            <div class="min-w-0">
              <p class="font-mono text-sm text-fg">{c.name}</p>
              <p class="font-mono text-xs text-fg-dim">{c.value}</p>
              <p class="text-xs text-fg-muted mt-1">{c.note}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Text on bg samples -->
    <section class="mb-16">
      <h2 class="text-xs font-mono uppercase tracking-widest text-accent mb-6">Text contrast samples</h2>
      <div class="card p-6 space-y-3">
        <p class="text-white">text-white — The quick brown fox jumps over the lazy dog.</p>
        <p class="text-fg">text-fg — The quick brown fox jumps over the lazy dog.</p>
        <p class="text-fg-muted">text-fg-muted — The quick brown fox jumps over the lazy dog.</p>
        <p class="text-fg-dim">text-fg-dim — The quick brown fox jumps over the lazy dog.</p>
        <p class="text-accent">text-accent — The quick brown fox jumps over the lazy dog.</p>
        <p class="text-accent2">text-accent2 — The quick brown fox jumps over the lazy dog.</p>
      </div>
    </section>

    <!-- Typography scale -->
    <section class="mb-16">
      <h2 class="text-xs font-mono uppercase tracking-widest text-accent mb-6">Typography — Inter (sans)</h2>
      <p class="text-fg-muted mb-4 text-sm">Root font-size is 19.2px (120%), so Tailwind rem-based sizes scale proportionally. 12px is the floor.</p>
      <div class="card p-6 space-y-4">
        <div>
          <p class="font-mono text-xs text-fg-dim mb-1">h1 / text-6xl / 3.75rem / 72px / bold 700</p>
          <h1 class="text-6xl font-bold text-white tracking-tight">Igor Gembitsky</h1>
        </div>
        <div>
          <p class="font-mono text-xs text-fg-dim mb-1">h1-responsive / text-4xl→5xl→6xl / 43→58→72px / bold</p>
          <p class="text-4xl sm:text-5xl md:text-6xl font-bold text-white tracking-tight">Hero headline size</p>
        </div>
        <div>
          <p class="font-mono text-xs text-fg-dim mb-1">h2 / text-4xl / 2.25rem / 43px / bold 700</p>
          <h2 class="text-4xl font-bold text-white">Section heading</h2>
        </div>
        <div>
          <p class="font-mono text-xs text-fg-dim mb-1">h3 / text-2xl / 1.5rem / 29px / semibold 600</p>
          <h3 class="text-2xl font-semibold text-white">Subsection</h3>
        </div>
        <div>
          <p class="font-mono text-xs text-fg-dim mb-1">tagline / text-xl→2xl / 24→29px / light 300 / gradient</p>
          <p class="text-xl sm:text-2xl font-light gradient-text">I build self-improving teams and self-evolving systems.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-fg-dim mb-1">body-lg / text-lg / 1.125rem / 22px / normal 400</p>
          <p class="text-lg text-fg-muted leading-relaxed max-w-2xl">
            14 years across science, education, media, fintech, luxury marketplaces, and industrial AI.
            Seven-plus teams and organizations built from zero.
          </p>
        </div>
        <div>
          <p class="font-mono text-xs text-fg-dim mb-1">body-base / text-base / 1rem / 19px / normal 400</p>
          <p class="text-base text-fg-muted max-w-2xl">
            Standard body copy size. Used in most card bodies and paragraph blocks throughout the site.
          </p>
        </div>
        <div>
          <p class="font-mono text-xs text-fg-dim mb-1">small / text-sm / 0.875rem / 17px / normal 400</p>
          <p class="text-sm text-fg-muted">Secondary body text and captions.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-fg-dim mb-1">xs / text-xs / 0.75rem / 14px / normal 400</p>
          <p class="text-xs text-fg-dim">Footer, fine print, labels.</p>
        </div>
        <div>
          <p class="font-mono text-xs text-fg-dim mb-1">floor / text-[12px] / 12px — minimum size</p>
          <p class="text-[12px] text-fg-dim">Tiny captions under podcast and tool tiles.</p>
        </div>
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-xs font-mono uppercase tracking-widest text-accent mb-6">Typography — JetBrains Mono</h2>
      <div class="card p-6 space-y-3">
        <p class="font-mono text-base text-fg">font-mono / text-base / 19px — const hello = "world"</p>
        <p class="font-mono text-sm text-fg-muted">font-mono / text-sm / 17px — nav labels, eyebrows</p>
        <p class="font-mono text-xs text-fg-dim">font-mono / text-xs / 14px — footer, metadata</p>
        <p class="font-mono text-[13px] text-fg-muted">font-mono / 13px — tags, expand triggers</p>
        <p class="font-mono text-[12px] uppercase tracking-[0.08em] text-accent">detail-label / 12px uppercase / letter-spacing 0.08em</p>
      </div>
    </section>

    <!-- Components -->
    <section class="mb-16">
      <h2 class="text-xs font-mono uppercase tracking-widest text-accent mb-6">Buttons</h2>
      <div class="card p-6 flex flex-wrap gap-3">
        <button class="btn-primary">Primary button</button>
        <button class="btn-secondary">Secondary button</button>
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-xs font-mono uppercase tracking-widest text-accent mb-6">Tags</h2>
      <div class="card p-6 flex flex-wrap gap-2">
        <span class="tag">default tag</span>
        <span class="tag">python</span>
        <span class="tag tag-accent">accent tag</span>
        <span class="tag tag-accent">featured</span>
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-xs font-mono uppercase tracking-widest text-accent mb-6">Surfaces</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="card p-6">
          <p class="font-mono text-xs text-fg-dim mb-2">.card</p>
          <p class="text-fg-muted text-sm">Gradient surface with border. Hover lifts it.</p>
        </div>
        <div class="p-6 rounded-xl" style="background: var(--color-surface); border: 1px solid var(--color-border);">
          <p class="font-mono text-xs text-fg-dim mb-2">surface</p>
          <p class="text-fg-muted text-sm">Flat surface swatch.</p>
        </div>
        <div class="p-6 rounded-xl" style="background: var(--color-surface-hover); border: 1px solid var(--color-border-hover);">
          <p class="font-mono text-xs text-fg-dim mb-2">surface-hover</p>
          <p class="text-fg-muted text-sm">Hover state swatch.</p>
        </div>
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-xs font-mono uppercase tracking-widest text-accent mb-6">Divider</h2>
      <hr class="section-divider" />
    </section>
  </main>
</BaseLayout>
